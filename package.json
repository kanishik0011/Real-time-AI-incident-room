{
  "name": "real-time-ai-incident-room",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev --workspace server\" \"npm:dev --workspace client\"",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "build:client": "npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "start:server": "npm run start --workspace server",
    "typecheck": "npm run typecheck --workspace client && npm run typecheck --workspace server",
    "lint": "npm run lint --workspace client",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

